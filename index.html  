// ══════════════════════════════════
// LAUNCH
// ══════════════════════════════════
function launch() {
  if (!curTheme || !curEv) return;
  const n1 = document.getElementById('fn1').value.trim();
  if (!n1) { alert(lang==='es' ? 'Escribe al menos un nombre.' : 'Please enter at least one name.'); return; }

  const t      = THEMES[curTheme];
  const copy   = COPY[lang].events[curEv];
  const n2     = document.getElementById('fn2').value.trim();
  const date   = document.getElementById('fdate').value.trim();
  const school = document.getElementById('fschool').value.trim();
  const venue  = selectedVenue;
  const dp     = document.getElementById('page-display');

  // Apply background
  dp.style.background = t.bg;

  // Apply accent colors to SVG corners
  dp.querySelectorAll('.corner svg path').forEach(p => p.setAttribute('stroke', t.a1));

  // Orbs
  document.getElementById('orb1').style.background = `radial-gradient(circle,${t.o1} 0%,transparent 70%)`;
  document.getElementById('orb2').style.background = `radial-gradient(circle,${t.o2} 0%,transparent 70%)`;

  // Ornament lines
  dp.querySelectorAll('.ol').forEach(e => e.style.background = `linear-gradient(to right,transparent,${t.a1})`);
  dp.querySelectorAll('.or').forEach(e => e.style.background = `linear-gradient(to left,transparent,${t.a1})`);
  dp.querySelectorAll('.od').forEach(e => { e.style.background=t.a1; e.style.boxShadow=`0 0 8px ${t.a2}`; });
  dp.querySelectorAll('.op').forEach(e => e.style.background = t.ad);
  dp.querySelectorAll('.d-dl').forEach(e => e.style.background = `linear-gradient(to right,transparent,${t.a1},transparent)`);
  dp.querySelectorAll('.d-dd').forEach(e => e.style.background = t.a1);
  dp.querySelectorAll('.d-ds').forEach(e => e.style.background = t.ad);

  // Text colors
  document.getElementById('d-line1').style.color  = t.a1;
  document.getElementById('d-names').style.color  = t.tx;
  document.getElementById('d-names').style.textShadow = `0 0 80px ${t.glow}`;
  // Update breathe animation to use theme glow color
  const glowColor = t.glow;
  const styleEl = document.getElementById('breathe-style') || document.createElement('style');
  styleEl.id = 'breathe-style';
  const gc = glowColor.replace('0.3','');
  styleEl.textContent = `@keyframes breathe { 0%,100%{text-shadow:0 0 40px ${gc}0.15), 0 0 80px ${gc}0.08)} 50%{text-shadow:0 0 80px ${gc}0.6), 0 0 150px ${gc}0.28), 0 0 220px ${gc}0.1)} }`;
  document.head.appendChild(styleEl);
  document.querySelector('.d-amp').style.color     = t.a2;
  document.getElementById('d-line3').style.color   = t.a2;
  document.getElementById('d-date').style.color    = `rgba(${hexToRgb(t.tx)},0.5)`;
  document.getElementById('d-school').style.color  = t.a1;

  // Venue
  const vc = document.getElementById('d-venue');
  const vl = document.querySelector('.d-vline');
  const vt = document.getElementById('d-venue-txt');
  if (venue) {
    vl.style.background = t.a1;
    vt.style.color = t.a1;
    vt.style.fontSize = 'clamp(10px,1vw,16px)';
    vt.textContent = venue;
    vc.style.display = 'flex';
  } else {
    vc.style.display = 'none';
  }

  // Fill text
  document.getElementById('d-line1').textContent = copy.line1;
  document.getElementById('d-n1').textContent    = n1;
  const amp = document.getElementById('d-amp');
  const dn2 = document.getElementById('d-n2');
  if (n2) { amp.style.display=''; dn2.style.display=''; dn2.textContent=n2; }
  else    { amp.style.display='none'; dn2.style.display='none'; }
  document.getElementById('d-line3').textContent = copy.line3;
  document.getElementById('d-date').textContent  = date;

  const sc = document.getElementById('d-school');
  if (school && curEv==='grad') { sc.textContent=school; sc.style.display='block'; } else sc.style.display='none';

  // Switch pages
  document.getElementById('page-setup').style.display = 'none';
  dp.style.display = 'flex';

  // Restart animations
  dp.querySelectorAll('.d-line1,.d-names,.d-divider,.d-line3,.d-date,.d-school,.corner').forEach(el => {
    el.style.animation = 'none'; void el.offsetWidth; el.style.animation = '';
  });
  dp.querySelectorAll('[style*="animation:fu"],[style*="animation:fi"]').forEach(el => {
    const a = el.style.animation; el.style.animation='none'; void el.offsetWidth; el.style.animation=a;
  });

  // Particles
  palette = t.p;
  initP(); if(!rafId) draw();
}

// helper
function hexToRgb(hex) {
  const r = parseInt(hex.slice(1,3),16);
  const g = parseInt(hex.slice(3,5),16);
  const b = parseInt(hex.slice(5,7),16);
  return `${r},${g},${b}`;
}

// ── EDIT ──
document.addEventListener('keydown', e => {
  if (e.key==='e'||e.key==='E') {
    document.getElementById('page-display').style.display = 'none';
    document.getElementById('page-setup').style.display   = 'flex';
    cancelAnimationFrame(rafId); rafId = null;
  }
});

// ══════════════════════════════════
// PARTICLES
// ══════════════════════════════════
const cv = document.getElementById('cv');
const cx = cv.getContext('2d');
let W, H, pts=[], palette=THEMES['boda-oro'].p, rafId=null;

function rsz() { W=cv.width=innerWidth; H=cv.height=innerHeight; }
rsz(); addEventListener('resize',()=>{ rsz(); initP(); });

// Safe zones where particles avoid (center of screen where text lives)
function inSafeZone(x, y) {
  const cx = W/2, cy = H/2;
  const zoneW = W*0.65, zoneH = H*0.55;
  return Math.abs(x-cx) < zoneW/2 && Math.abs(y-cy) < zoneH/2;
}

function mkP(rnd) {
  const c = palette[Math.floor(Math.random()*palette.length)];
  const r = Math.random()*2.2+0.8;
  let x, y;
  // Place particles outside the text safe zone
  let attempts = 0;
  do {
    x = Math.random()*W;
    y = rnd ? Math.random()*H : H + r + 5;
    attempts++;
  } while(rnd && inSafeZone(x,y) && attempts < 20);

  return {
    x, y, r,
    vy: -(Math.random()*.3+.06),
    vx: (Math.random()-.5)*.12,
    o:0, mo: Math.random()*0.6+0.2,
    fs: Math.random()*.004+.002,
    st:'in', ht:0, hd: Math.random()*350+200,
    c, tw: Math.random()*Math.PI*2,
    tws: Math.random()*.013+.004
  };
}

function initP() {
  pts=[];
  const n = Math.floor(W*H/7000);
  for(let i=0;i<n;i++) pts.push(mkP(true));
}

function draw() {
  cx.clearRect(0,0,W,H);
  pts.forEach((p,i)=>{
    p.x+=p.vx; p.y+=p.vy; p.tw+=p.tws;
    const tw=p.mo*(.7+.3*Math.sin(p.tw));
    if(p.st==='in'){p.o=Math.min(p.o+p.fs,tw);if(p.o>=p.mo*.9)p.st='hold';}
    else if(p.st==='hold'){p.o=tw;p.ht++;if(p.ht>p.hd)p.st='out';}
    else{p.o=Math.max(p.o-p.fs,0);if(p.o<=0)pts[i]=mkP(false);}
    if(p.y<-8)pts[i]=mkP(false);

    // Skip drawing if particle drifted into text zone
    if(inSafeZone(p.x,p.y)){p.y=H+5;return;}

    // Clean dot only — no glow circle
    cx.beginPath();cx.arc(p.x,p.y,p.r,0,Math.PI*2);
    cx.fillStyle=p.c+p.o.toFixed(3)+')';cx.fill();
  });
  rafId=requestAnimationFrame(draw);
}
</script>
