<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Welcome Screen</title>
<style>
* { margin:0; padding:0; box-sizing:border-box; }
html, body { width:100%; height:100%; font-family:Georgia,serif; background:#050505; }

/* ═══════════════════════
   SETUP PAGE
═══════════════════════ */
#page-setup {
  width:100%; min-height:100vh;
  background:#F5F0E8;
  display:flex; flex-direction:column; align-items:center;
  padding:36px 20px 80px;
}

.s-title {
  font-size:22px; letter-spacing:5px;
  color:#3A2800; text-transform:uppercase;
  margin-bottom:6px; text-align:center;
}
.s-sub {
  font-size:15px; color:#7A6030;
  letter-spacing:2px; font-style:italic;
  margin-bottom:28px; text-align:center;
}

/* LANGUAGE SELECTOR */
.lang-wrap {
  width:min(500px,94vw);
  display:flex; gap:8px; margin-bottom:20px;
}
.lang-btn {
  flex:1; padding:14px;
  background:#fff; border:2px solid #D4B060;
  color:#7A6030; font-size:15px; letter-spacing:3px;
  text-transform:uppercase; cursor:pointer;
  text-align:center; user-select:none;
  transition:all .15s;
}
.lang-btn:hover { border-color:#8B6914; color:#3A2800; }
.lang-btn.active { border-color:#8B6914; color:#3A2800; background:#FFF8E8; font-weight:bold; }

/* ACCORDION MENU */
.menu { width:min(500px,94vw); margin-bottom:20px; }

.cat-hd {
  display:flex; justify-content:space-between; align-items:center;
  padding:14px 18px; margin-bottom:3px;
  background:#fff; border:1px solid #D4B060;
  color:#3A2800; font-size:14px; letter-spacing:3px;
  text-transform:uppercase; cursor:pointer; user-select:none;
  transition:all .15s;
}
.cat-hd:hover { background:#FFF8E8; }
.cat-hd.open { background:#FFF3CC; border-color:#8B6914; color:#1A1000; font-weight:bold; }
.cat-hd .arr { transition:transform .2s; font-size:11px; color:#8B6914; }
.cat-hd.open .arr { transform:rotate(180deg); }

.cat-body { display:none; margin-bottom:6px; }
.cat-body.open { display:block; }

.theme-opt {
  display:flex; align-items:center; gap:14px;
  padding:12px 28px;
  background:#FAFAFA; border:1px solid #E0C878; border-top:none;
  color:#5A4000; font-size:17px; cursor:pointer; user-select:none;
  transition:all .12s;
}
.theme-opt:hover { background:#FFF8E8; color:#1A1000; }
.theme-opt.active { color:#1A1000; background:#FFF3CC; border-color:#8B6914; font-weight:bold; }
.tdot { width:12px; height:12px; border-radius:50%; flex-shrink:0; }

/* FIELDS */
.sep { width:min(500px,94vw); height:1px; background:linear-gradient(to right,transparent,#D4B060,transparent); margin:16px 0; }

.fields { width:min(500px,94vw); display:flex; flex-direction:column; gap:14px; }
.field { display:flex; flex-direction:column; gap:5px; }
.field label { font-size:11px; letter-spacing:3px; color:#7A6030; text-transform:uppercase; font-weight:bold; }
.field input {
  background:#fff; border:2px solid #D4B060;
  color:#1A1000; font-family:Georgia,serif;
  font-size:20px; padding:13px 16px;
  outline:none; width:100%;
  transition:border-color .15s;
}
.field input:focus { border-color:#8B6914; }
.field input::placeholder { color:#C4A060; font-style:italic; }

#btn-go {
  margin-top:24px;
  background:#3A2800; border:2px solid #3A2800;
  color:#E8C96B; font-family:Georgia,serif;
  font-size:13px; letter-spacing:5px; text-transform:uppercase;
  padding:18px 56px; cursor:pointer;
  transition:all .2s;
}
#btn-go:disabled { opacity:.3; cursor:default; background:#ccc; border-color:#ccc; color:#888; }
#btn-go:not(:disabled):hover { background:#1A1000; }

.tip { font-size:13px; color:#9A8050; letter-spacing:2px; font-style:italic; margin-top:12px; text-align:center; }

/* ═══════════════════════
   DISPLAY PAGE
═══════════════════════ */
#page-display {
  display:none; position:fixed; inset:0; z-index:999;
  flex-direction:column; align-items:center; justify-content:center;
  background:#060608;
}

#cv { position:absolute; inset:0; z-index:0; }
.vignette { position:absolute; inset:0; z-index:1; background:radial-gradient(ellipse at center,transparent 20%,rgba(0,0,0,0.55) 65%,rgba(0,0,0,0.88) 100%); pointer-events:none; }

#orb1,#orb2 { position:absolute; border-radius:50%; filter:blur(90px); z-index:1; pointer-events:none; }
#orb1 { width:500px; height:500px; top:-120px; left:-80px; }
#orb2 { width:400px; height:400px; bottom:-80px; right:-60px; }

/* corners */
.corner { position:fixed; z-index:3; width:50px; height:50px; opacity:0; animation:fi 2s ease 3s forwards; }
.corner svg { width:100%; height:100%; }
.c-tl{top:24px;left:24px} .c-tr{top:24px;right:24px;transform:scaleX(-1)} .c-bl{bottom:24px;left:24px;transform:scaleY(-1)} .c-br{bottom:24px;right:24px;transform:scale(-1,-1)}

/* content */
.d-content { position:relative; z-index:2; display:flex; flex-direction:column; align-items:center; padding:0 40px; width:100%; }

/* ornament */
.orn { display:flex; align-items:center; gap:16px; }
.ol { width:70px; height:1px; background:linear-gradient(to right,transparent,#C9A84C); }
.or { width:70px; height:1px; background:linear-gradient(to left,transparent,#C9A84C); }
.od { width:7px; height:7px; transform:rotate(45deg); background:#C9A84C; animation:diamond-glow 3s ease-in-out infinite; }
.op { width:3px; height:3px; border-radius:50%; background:#7A6030; }

/* text layers */
.d-line1 {
  font-size:clamp(18px,2.2vw,36px); letter-spacing:4px;
  color:#C9A84C; text-transform:uppercase;
  margin:22px 0 0; text-align:center;
  opacity:0; animation:fu 1.8s ease .6s forwards;
  padding:0 20px;
  line-height:1.3;
}
.d-names {
  font-size:clamp(72px,11vw,160px);
  font-weight:300; font-style:italic;
  color:#FAF6EE; text-align:center;
  line-height:1; margin:14px 0 0;
  opacity:0; animation:fu 2s ease 1s forwards, breathe 5s ease-in-out 3s infinite;
  text-shadow:0 0 80px rgba(201,168,76,0.3);
  padding:0 20px;
  word-break:break-word;
}
.d-amp { font-size:.65em; color:#E8C96B; margin:0 .12em; font-style:normal; }

.d-divider {
  display:flex; align-items:center; gap:18px;
  margin:20px 0;
  opacity:0; animation:fi 1.8s ease 1.6s forwards;
}
.d-dl { width:120px; height:1px; background:linear-gradient(to right,transparent,#C9A84C,transparent); opacity:.5; }
.d-dc { display:flex; align-items:center; gap:10px; }
.d-dd { width:6px; height:6px; transform:rotate(45deg); background:#C9A84C; animation:diamond-glow 3s ease-in-out infinite; }
.d-ds { width:4px; height:4px; transform:rotate(45deg); background:#7A6030; }

.d-line3 {
  font-size:clamp(16px,2vw,32px); letter-spacing:4px;
  color:#E8C96B; text-transform:uppercase;
  text-align:center;
  opacity:0; animation:fu 1.8s ease 1.9s forwards;
  padding:0 20px;
  line-height:1.3;
}
.d-date {
  font-size:clamp(16px,1.8vw,28px); font-weight:300; letter-spacing:5px;
  color:rgba(250,246,238,0.55); text-transform:uppercase;
  margin-top:10px; text-align:center;
  opacity:0; animation:fu 1.8s ease 2.1s forwards;
}
.d-school {
  font-size:clamp(13px,1.3vw,20px); letter-spacing:3px;
  text-transform:uppercase; margin-top:8px;
  text-align:center; display:none;
  opacity:0; animation:fu 1.8s ease 2.2s forwards;
  padding:0 20px;
}

/* venue */
#d-venue {
  position:fixed; bottom:32px; right:40px;
  z-index:5; display:none; align-items:center; gap:10px;
  opacity:0; animation:fi 2s ease 3.2s forwards;
}
.d-vline { width:26px; height:1px; }
.d-vtxt { font-size:clamp(7px,.7vw,11px); letter-spacing:4px; text-transform:uppercase; }

/* gender reveal special colors */
.gender-line1 { color:#E882B4 !important; }
.gender-line3 { color:#82BEE8 !important; }
.gender-ornament-pink .od { background:#E882B4 !important; box-shadow:0 0 8px #E882B4 !important; }

/* animations */
@keyframes fu { from{opacity:0;transform:translateY(18px)} to{opacity:1;transform:translateY(0)} }
@keyframes fi { from{opacity:0} to{opacity:1} }
@keyframes breathe { 0%,100%{text-shadow:0 0 40px rgba(201,168,76,0.15), 0 0 80px rgba(201,168,76,0.1)} 50%{text-shadow:0 0 80px rgba(201,168,76,0.55), 0 0 140px rgba(201,168,76,0.25), 0 0 200px rgba(201,168,76,0.1)} }
@keyframes diamond-glow { 0%,100%{box-shadow:0 0 4px rgba(201,168,76,0.2), 0 0 8px rgba(201,168,76,0.1)} 50%{box-shadow:0 0 12px rgba(201,168,76,0.9), 0 0 24px rgba(201,168,76,0.5), 0 0 40px rgba(201,168,76,0.2)} }
</style>
</head>
